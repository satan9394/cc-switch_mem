{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CC Switch",
        "titleBarStyle": "Visible",
        "visible": false,
        "minWidth": 900,
        "minHeight": 600
      }
    ]
  },
  "bundle": {
    "targets": ["nsis"],
    "resources": {
      "resources/suite/": "resources/suite/"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "./windows/suite-hooks.nsh"
      }
    }
  }
}
